{
  "manifest_version": 3,
  "name": "ByeBar — Overlay & Popup Blocker",
  "short_name": "ByeBar",
  "description": "Removes newsletter nags, subscribe overlays, email capture popups, and auto-declines cookie consent banners. Not an ad blocker.",
  "version": "0.2.0",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "ByeBar",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "shared/browser.js",
        "content/safari-compat.js",
        "content/geolocation.js",
        "content/selectors.js",
        "content/shadow.js",
        "content/engine.js",
        "content/cookies.js",
        "content/tos.js",
        "content/china-commerce.js",
        "content/main.js"
      ],
      "css": ["content/styles.css", "content/styles-safari.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.substack.com/*", "*://substack.com/*"],
      "css": ["content/substack.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.bloomberg.com/*", "*://*.bloomberg.co.jp/*", "*://*.bloomberg.tv/*"],
      "css": ["content/bloomberg.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.temu.com/*",
        "*://*.shein.com/*",
        "*://*.aliexpress.com/*",
        "*://*.pinduoduo.com/*",
        "*://*.yangkeduo.com/*",
        "*://*.taobao.com/*",
        "*://*.tmall.com/*",
        "*://*.jd.com/*"
      ],
      "css": ["content/china-commerce.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "byebar@neuralnexus.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "safari": {
      "strict_min_version": "16.4"
    }
  }
}
