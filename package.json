{
  "name": "byebar",
  "version": "0.5.0",
  "private": true,
  "description": "ByeBar; Overlay & Popup Blocker (Chrome, Firefox, Safari)",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "validate": "node scripts/validate-manifest.mjs && npm run lint && npm run format:check && npm run test:run",
    "build:safari": "bash scripts/build-safari.sh",
    "icons": "node scripts/generate-icons.mjs",
    "build:store": "node scripts/generate-icons.mjs && node scripts/build-chrome-store.mjs",
    "build:store:crx": "node scripts/generate-icons.mjs && node scripts/build-chrome-crx.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "sharp": "^0.35.3",
    "vitest": "^3.0.8"
  }
}
